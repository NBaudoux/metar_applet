{
    "UPDATE_CONFIG": {
        "type": "header",
        "description": "METAR update"
    },
    "AD_ICAO": {
        "type" : "entry",
        "default": "EKRK",
        "description": "AD's ICAO you want to get the METAR from"
    },    
    "OBSERVATION_TIMES": {
        "type" : "entry",
        "default": "20,50",
        "description": "Comma-separated list of minutes in an hour when the observation are made"
    },
    "UPDATE_DELAY": {
        "type" : "spinbutton",
        "default": 4,
        "min": 0,
        "max": 10,
        "step": 1,
        "units": "minutes",
        "description": "Delay between METAR's observation & update time"
    },
    "APPEARANCE_CONFIG": {
        "type": "header",
        "description": "Appearance"
    },
    "LINE_LENGTH": {
        "type" : "spinbutton",
        "default": 50,
        "min": 20,
        "max": 60,
        "step": 1,
        "units": "characters",
        "description": "Length of the METAR's line"
    },
    "TWO_LINES": {
        "type": "checkbox", 
        "default": "true",
        "description": "Show the METAR on 2 lines if too long"
    }
}